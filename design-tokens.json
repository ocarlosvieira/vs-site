{
  "color": {
    "background": {
      "primary": "#0A0E1A",
      "secondary": "#111827",
      "card": "#1A1F2E",
      "cardHover": "#232838",
      "elevated": "#252A3A"
    },
    "accent": {
      "blue": "#3B82F6",
      "blueLight": "#60A5FA",
      "orange": "#F97316",
      "orangeLight": "#FB923C",
      "purple": "#8B5CF6"
    },
    "text": {
      "primary": "#F9FAFB",
      "secondary": "#9CA3AF",
      "muted": "#6B7280",
      "accent": "#3B82F6"
    },
    "border": {
      "default": "#1F2937",
      "subtle": "#374151",
      "accent": "rgba(59, 130, 246, 0.25)"
    }
  },
  "gradient": {
    "hero": "linear-gradient(135deg, #3B82F6, #8B5CF6)",
    "warm": "linear-gradient(135deg, #F97316, #EF4444)",
    "glow": "radial-gradient(ellipse at center, rgba(59,130,246,0.15), transparent 70%)"
  },
  "typography": {
    "fontFamily": {
      "display": "'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif",
      "body": "'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "'JetBrains Mono', 'Fira Code', monospace"
    },
    "fontSize": {
      "display": "3.5rem",
      "h1": "2.5rem",
      "h2": "2rem",
      "h3": "1.5rem",
      "body": "1rem",
      "bodySm": "0.875rem",
      "caption": "0.75rem",
      "button": "0.875rem"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.1,
      "snug": 1.2,
      "normal": 1.4,
      "relaxed": 1.6
    }
  },
  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "borderRadius": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "2xl": "1.5rem",
    "full": "9999px"
  },
  "shadow": {
    "card": "0 4px 24px rgba(0, 0, 0, 0.3)",
    "elevated": "0 8px 32px rgba(0, 0, 0, 0.4)",
    "glowBlue": "0 0 40px rgba(59, 130, 246, 0.15)",
    "glowOrange": "0 0 40px rgba(249, 115, 22, 0.15)"
  },
  "blur": {
    "glass": "12px",
    "heavy": "24px"
  },
  "breakpoint": {
    "mobile": "0px",
    "tablet": "640px",
    "desktop": "1024px",
    "wide": "1280px"
  },
  "container": {
    "maxWidth": "1280px",
    "paddingMobile": "1.5rem",
    "paddingDesktop": "2rem"
  },
  "animation": {
    "duration": {
      "fast": "150ms",
      "normal": "200ms",
      "slow": "400ms",
      "pulse": "3000ms"
    },
    "easing": {
      "default": "ease-out",
      "smooth": "ease-in-out",
      "snappy": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  }
}
